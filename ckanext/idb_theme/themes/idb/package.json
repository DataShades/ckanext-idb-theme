{
    "scripts": {
        "watch-scripts": "vite build -w",
        "build-scripts": "vite build",
        "typecheck-scripts": "tsc --noEmit",
        "watch-styles": "sass -Inode_modules  -w assets/scss/main.scss assets/css/main.css --embed-source-map",
