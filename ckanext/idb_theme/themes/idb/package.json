    },
    "dependencies": {
        "@types/bootstrap": "^5.2.10",
        "@types/node": "^25.9.2",
        "bootstrap": "^5.3.3",
        "sass": "^1.99.0",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "vite": "^8.0.16",
        "vite-plugin-checker": "^0.14.1"
    }
}
